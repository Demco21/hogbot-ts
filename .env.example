# Discord Configuration
DISCORD_TOKEN=your_bot_token_here

# OPTIONAL: Guild ID for development/single-server mode
# If set, commands will be registered only to this guild (faster updates during dev)
# If not set, commands will be registered globally (takes ~1 hour to update)
GUILD_ID=1262202594064076932

# DEPRECATED: These are now configured per-guild using the /config command
# Kept for backward compatibility only
# CASINO_CHANNEL_ID=1262202594596622458
# RICHEST_MEMBER_ROLE_ID=1269016290614448239

# Database Configuration (SQLite)
# Path to the SQLite database file. Defaults to ./hogbot.db if not set.
DATABASE_FILE=./hogbot.db

# Bot Configuration
NODE_ENV=development

# AI Configuration
# API key for the Anthropic API, used by the HogAI @mention trigger
ANTHROPIC_API_KEY=your_anthropic_api_key_here
